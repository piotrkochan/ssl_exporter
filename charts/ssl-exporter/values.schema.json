{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "imageRegistry": {
          "type": "string"
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "namespaceOverride": {
      "type": "string"
    },
    "commonLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "deploymentAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "registry": {
          "type": "string"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "ipDualStack": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "ipFamilies": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["IPv4", "IPv6"]
              }
            },
            "ipFamilyPolicy": {
              "type": "string",
              "enum": ["SingleStack", "PreferDualStack", "RequireDualStack"]
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allowMonitoringNamespace": {
          "type": "boolean"
        },
        "monitoringNamespaceName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extraEnvFrom": {
      "type": "array"
    },
    "strategy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["RollingUpdate", "Recreate"]
        },
        "rollingUpdate": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "priorityClassName": {
      "type": "string"
    },
    "dnsPolicy": {
      "type": "string"
    },
    "dnsConfig": {
      "type": "object",
      "additionalProperties": true
    },
    "topologySpreadConstraints": {
      "type": "array"
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true
    },
    "rbac": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "automountServiceAccountToken": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "scrapeTimeout": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "targetLabels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "podTargetLabels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "honorLabels": {
          "type": "boolean"
        },
        "honorTimestamps": {
          "type": "boolean"
        },
        "proxyUrl": {
          "type": "string"
        },
        "sampleLimit": {
          "type": "integer",
          "minimum": 0
        },
        "targetLimit": {
          "type": "integer",
          "minimum": 0
        },
        "labelLimit": {
          "type": "integer",
          "minimum": 0
        },
        "labelNameLengthLimit": {
          "type": "integer",
          "minimum": 0
        },
        "labelValueLengthLimit": {
          "type": "integer",
          "minimum": 0
        },
        "tlsConfig": {
          "type": "object",
          "additionalProperties": true
        },
        "basicAuth": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "webConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "secretName": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "secretName": {
          "type": "string"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "certManager": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "issuerRef": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": {
                  "type": "string"
                },
                "kind": {
                  "type": "string",
                  "enum": ["Issuer", "ClusterIssuer"]
                }
              }
            },
            "duration": {
              "type": "string"
            },
            "renewBefore": {
              "type": "string"
            },
            "dnsNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingConfigMap": {
          "type": "string"
        },
        "data": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["tls"],
        "properties": {
          "tls": {
            "required": ["enabled"],
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "tls": {
            "anyOf": [
              {
                "properties": {
                  "secretName": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["secretName"]
              },
              {
                "properties": {
                  "certManager": {
                    "properties": {
                      "enabled": {
                        "const": true
                      },
                      "issuerRef": {
                        "properties": {
                          "name": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "required": ["name"]
                      }
                    },
                    "required": ["enabled", "issuerRef"]
                  }
                },
                "required": ["certManager"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": ["tls"],
        "properties": {
          "tls": {
            "required": ["certManager"],
            "properties": {
              "certManager": {
                "required": ["enabled"],
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "tls": {
            "properties": {
              "certManager": {
                "required": ["issuerRef"],
                "properties": {
                  "issuerRef": {
                    "required": ["name"],
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
