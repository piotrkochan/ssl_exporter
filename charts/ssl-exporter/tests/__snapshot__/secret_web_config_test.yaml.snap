generates empty config when no data and no tls:
  1: |
    apiVersion: v1
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ssl-exporter
        app.kubernetes.io/version: 2.5.1
        helm.sh/chart: ssl-exporter-0.1.0
      name: RELEASE-NAME-ssl-exporter-web-config
    stringData:
      web-config.yaml: |
        {}
    type: Opaque
injects tls_server_config when tls enabled:
  1: |
    apiVersion: v1
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ssl-exporter
        app.kubernetes.io/version: 2.5.1
        helm.sh/chart: ssl-exporter-0.1.0
      name: RELEASE-NAME-ssl-exporter-web-config
    stringData:
      web-config.yaml: |
        tls_server_config:
          cert_file: /etc/tls/tls.crt
          key_file: /etc/tls/tls.key
    type: Opaque
injects tls_server_config with custom mountPath:
  1: |
    apiVersion: v1
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ssl-exporter
        app.kubernetes.io/version: 2.5.1
        helm.sh/chart: ssl-exporter-0.1.0
      name: RELEASE-NAME-ssl-exporter-web-config
    stringData:
      web-config.yaml: |
        tls_server_config:
          cert_file: /custom/certs/tls.crt
          key_file: /custom/certs/tls.key
    type: Opaque
merges user data with tls config:
  1: |
    apiVersion: v1
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ssl-exporter
        app.kubernetes.io/version: 2.5.1
        helm.sh/chart: ssl-exporter-0.1.0
      name: RELEASE-NAME-ssl-exporter-web-config
    stringData:
      web-config.yaml: |
        basic_auth_users:
          admin: $2y$10$hash
        tls_server_config:
          cert_file: /etc/tls/tls.crt
          key_file: /etc/tls/tls.key
    type: Opaque
renders basic_auth_users without tls:
  1: |
    apiVersion: v1
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ssl-exporter
        app.kubernetes.io/version: 2.5.1
        helm.sh/chart: ssl-exporter-0.1.0
      name: RELEASE-NAME-ssl-exporter-web-config
    stringData:
      web-config.yaml: |
        basic_auth_users:
          admin: $2y$10$hash
    type: Opaque
